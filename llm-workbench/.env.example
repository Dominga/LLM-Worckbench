# Path to llama-server binary (mainline llama.cpp or fork like ik_llama.cpp)
LLAMA_SERVER_BIN=/home/lex/Documents/ML/ik_llama.cpp/build/bin/llama-server

# Working directory for the binary (matters for forks that use relative paths)
LLAMA_SERVER_CWD=/home/lex/Documents/ML/ik_llama.cpp

# GGUF model path
LLAMA_MODEL=/mnt/h/ML/Qwen/Qwen3.6-35B-A3B-UD-Q4_K_M.gguf

# Host/port the server listens on
LLAMA_HOST=127.0.0.1
LLAMA_PORT=8080

# Extra args passed verbatim to llama-server (space-separated)
# These are appended after -m, --host, --port.
LLAMA_EXTRA_ARGS=-c 131072 --jinja --fit -t 16 -b 2048 --cache-type-k q8_0 --cache-type-v q8_0

# Health-check timeout (seconds) — how long to wait for /health to return ok
LLAMA_HEALTH_TIMEOUT=120

# Auto-start llama-server on app launch (true/false)
LLAMA_AUTOSTART=true

# Optional: path to a markdown file loaded into the editor on startup.
# Used for editor stress-testing (large docs). Empty = use built-in placeholder.
LOAD_DOC_PATH=testdata/stress.md
